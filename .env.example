# =============================================================================
# Database (PostgreSQL 15+)
# =============================================================================
# For local development:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/real-estate-saas
#
# For Vercel deployment (use your Vercel Postgres or Neon connection string):
# DATABASE_URL=postgres://username:password@host:5432/database?sslmode=require

DATABASE_URL=postgresql://postgres:password@your-host:5432/database

# =============================================================================
# Payload CMS Secret
# =============================================================================
# IMPORTANT: Generate a unique secret for each environment
# Generate with: openssl rand -base64 32
PAYLOAD_SECRET=change-this-to-a-unique-secret

# =============================================================================
# Server URLs
# =============================================================================
# Local development:
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# For production (update after deploying to Vercel):
# NEXT_PUBLIC_BASE_URL=https://your-site.vercel.app

# =============================================================================
# Optional: Google Places API (for POI features)
# =============================================================================
# GOOGLE_PLACES_API_KEY=your_google_places_api_key
