{
  "compilerOptions": {
    "composite": true,
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@payload/*": ["./payload/*"],
      "@frontend/*": ["./frontend/*"],
      "@shared/*": ["./packages/shared/*"]
    }
  },
  "references": [
    { "path": "./packages/shared" },
    { "path": "./frontend" },
    { "path": "./payload" }
  ],
  "include": []
}
